# Copy this to .env.local for local dev, then add these in Vercel dashboard under Settings > Environment Variables

# Get this from your Neon dashboard (Connection string)
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Admin login credentials — change these!
ADMIN_USERNAME=your_admin_username
ADMIN_PASSWORD=your_secure_password_here

# Random secret for session tokens — generate one at: https://generate-secret.vercel.app/32
SESSION_SECRET=replace_with_a_long_random_string
